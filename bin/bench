#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECK_RETRIES="${BENCH_CHECK_RETRIES:-45}"
CHECK_DELAY="${BENCH_CHECK_DELAY:-2}"

cmd="${1:-help}"
shift || true

help() {
  cat <<'TXT'
atoll-benchmarks

Commands:
  bench up                     Start benchmark stack via docker compose
  bench down                   Stop benchmark stack
  bench ps                     Show benchmark containers
  bench check                  Check endpoint reachability (HTTP status)
  bench run [args...]          Run benchmark and write JSON report
  bench report [args...]       Render markdown report from JSON

Examples:
  ./bin/bench up
  ./bin/bench check
  BENCH_CHECK_RETRIES=60 ./bin/bench check
  ./bin/bench run --rounds=3
  ./bin/bench report --out=benchmarks/results/latest.md
TXT
}

check_once() {
  local failed=0

  check_url() {
    local name="$1"
    local url="$2"
    local code
    code="$(curl -s -o /dev/null -w '%{http_code}' "$url" 2>/dev/null || true)"
    if [[ ! "$code" =~ ^[0-9]{3}$ ]]; then
      code="000"
    fi
    echo "$name $code"
    if [ "$code" != "200" ]; then
      failed=1
    fi
  }

  check_url atoll http://127.0.0.1:8080/
  check_url wordpress http://127.0.0.1:8081/
  check_url kirby http://127.0.0.1:8082/
  check_url grav http://127.0.0.1:8083/

  return "$failed"
}

wait_for_healthy() {
  local attempt=1
  while [ "$attempt" -le "$CHECK_RETRIES" ]; do
    echo "health-check attempt $attempt/$CHECK_RETRIES"
    if check_once; then
      return 0
    fi
    if [ "$attempt" -lt "$CHECK_RETRIES" ]; then
      sleep "$CHECK_DELAY"
    fi
    attempt=$((attempt + 1))
  done
  return 1
}

case "$cmd" in
  up)
    docker compose -f "$ROOT/docker-compose.yml" up -d --build
    ;;
  down)
    docker compose -f "$ROOT/docker-compose.yml" down
    ;;
  ps)
    docker compose -f "$ROOT/docker-compose.yml" ps
    ;;
  check)
    if ! wait_for_healthy; then
      echo "One or more endpoints are not healthy (expected 200)." >&2
      exit 1
    fi
    ;;
  run)
    if ! wait_for_healthy; then
      echo "Benchmark aborted: target stack is not healthy (expected 200)." >&2
      exit 1
    fi
    php "$ROOT/tools/benchmark-run.php" --root="$ROOT" "$@"
    ;;
  report)
    php "$ROOT/tools/benchmark-report.php" --root="$ROOT" "$@"
    ;;
  help|--help|-h)
    help
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    help
    exit 1
    ;;
esac
